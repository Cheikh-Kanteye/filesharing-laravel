# Deps (réinstallés dans l'image)
node_modules/
vendor/

# Git
.git/
.gitignore

# Env (fourni via env_file à runtime, ne pas baker dans l'image)
.env
.env.local
.env.*.local

# Logs & cache runtime
storage/logs/
storage/framework/cache/data/
storage/framework/sessions/
storage/framework/views/
bootstrap/cache/*.php

# Assets buildés (reconstruits dans l'image via stage Node)
public/build/

# Dev / tests / docs
tests/
*.md
.github/
.vscode/
.idea/

# Docker files (pas besoin dans le contexte de build)
docker-compose*.yml
Dockerfile
.dockerignore
